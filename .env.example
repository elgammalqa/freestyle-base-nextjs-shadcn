# Required: postgres connection string. Validated at boot via lib/env.ts.
# Buildra auto-provisions a Neon database for fullstack apps; the value
# is wired in automatically on the live preview. For local dev:
#   1. Create a free Neon project at https://neon.tech
#   2. Copy the pooled connection string here
#   3. Run `npm run db:push` to create the customers + deals tables
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Optional: where the app is hosted. Used by lib/api-client/custom-fetch.ts
# to resolve relative URLs during SSR. Defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set automatically by Vercel — leave blank locally.
# VERCEL_URL=
